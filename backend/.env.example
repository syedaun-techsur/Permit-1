NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgres://permits_user:CHANGE_ME@localhost:5432/permits
DB_HOST=localhost
DB_PORT=5432
DB_NAME=permits
DB_USER=permits_user
DB_PASS=CHANGE_ME

# JWT
JWT_SECRET=CHANGE_ME_minimum_256_bits_random_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=permits-documents

# Frontend
FRONTEND_URL=http://localhost:5173

# Seeding
RUN_MIGRATIONS=true
RUN_SEED=true
